#!/bin/bash

## Description: Run Vite commands (dev, build, preview)
## Usage: vite [command]
## Example: ddev vite dev

# Dynamically find the theme name from Silverstripe configuration
THEME_NAME=$(php -r "
    include_once 'vendor/autoload.php';
    \$config = shell_exec('sake config:dump');
    if (preg_match('/ssviewer:\s+themes:\s+(.*?)(?:\s+\w+:|$)/s', \$config, \$matches)) {
        if (preg_match_all('/-\s+([^$\s][\w-]+)/', \$matches[1], \$themeMatches)) {
            echo \$themeMatches[1][0] ?? '';
        }
    }
")

if [ -z "$THEME_NAME" ]; then
    echo "Error: Could not determine theme name from Silverstripe configuration."
    exit 1
fi

THEME_PATH="themes/$THEME_NAME"

if [ ! -d "$THEME_PATH" ]; then
    echo "Error: Theme directory $THEME_PATH does not exist."
    exit 1
fi

echo "--- Using theme: $THEME_NAME ---"
cd "$THEME_PATH"
yarn run dev "$@"
